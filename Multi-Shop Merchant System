on("chat:message", function (msg) {
    try {
        if (msg.type !== "api") return;

        const GOLD_ATTR = "gp";
        const SELL_RATE = 0.5;

        if (!state.CustomShopSystem) state.CustomShopSystem = {};
        if (!state.CustomShopSystem.items) state.CustomShopSystem.items = {};
        if (!state.CustomShopSystem.templates) state.CustomShopSystem.templates = {};

        const ITEM_DATA = state.CustomShopSystem.items;
        const TEMPLATES = state.CustomShopSystem.templates;

        function whisper(msgObj, text) {
            const player = getObj("player", msgObj.playerid);
            const displayName = player ? player.get("_displayname").replace(/\s*\(GM\)\s*$/, "") : "gm";
            sendChat("Merchant", `/w "${displayName}" ${text}`);
        }

        function isGM(msgObj) {
            return playerIsGM(msgObj.playerid);
        }

        function sanitizeKey(key) {
            return String(key || "")
                .trim()
                .toLowerCase()
                .replace(/[^a-z0-9_]/g, "_")
                .replace(/_+/g, "_")
                .replace(/^_+|_+$/g, "");
        }

        function normalizeCategory(cat) {
            return String(cat || "").trim().toLowerCase();
        }

        function button(command, label) {
            return `[${label}](${command})`;
        }

        function getAttr(charId, name) {
            return findObjs({ type: "attribute", characterid: charId, name: name })[0] || null;
        }

        function getAttrValue(charId, name, fallback) {
            const attr = getAttr(charId, name);
            if (!attr) return fallback;
            const raw = attr.get("current");
            if (typeof fallback === "string") return (raw == null ? fallback : String(raw));
            const num = parseFloat(raw);
            return isNaN(num) ? fallback : num;
        }

        function setOrCreateAttr(charId, name, value) {
            let attr = getAttr(charId, name);
            if (attr) {
                attr.set("current", value);
            } else {
                createObj("attribute", {
                    characterid: charId,
                    name: name,
                    current: value
                });
            }
        }

        function appendNote(charId, line) {
            const noteAttr = "merchant_loot";
            const oldText = getAttrValue(charId, noteAttr, "");
            const newText = oldText ? (oldText + "\n" + line) : line;
            setOrCreateAttr(charId, noteAttr, newText);
        }

        function rowID() {
            return "-" + Math.random().toString(36).substring(2, 10) + Math.random().toString(36).substring(2, 10);
        }

        function findRow(charId, itemName) {
            const attrs = findObjs({ type: "attribute", characterid: charId });
            const regex = /^repeating_inventory_([^_]+)_itemname$/;
            for (let i = 0; i < attrs.length; i++) {
                const attr = attrs[i];
                const match = attr.get("name").match(regex);
                if (match && String(attr.get("current")).trim() === itemName) {
                    return match[1];
                }
            }
            return null;
        }

        function getInventoryCount(charId, rowId) {
            return getAttrValue(charId, `repeating_inventory_${rowId}_itemcount`, 0);
        }

        function setInventoryCount(charId, rowId, count) {
            setOrCreateAttr(charId, `repeating_inventory_${rowId}_itemcount`, count);
        }

        function removeInventoryRow(charId, rowId) {
            const attrs = findObjs({ type: "attribute", characterid: charId });
            attrs.forEach(function (attr) {
                const n = attr.get("name");
                if (n.indexOf(`repeating_inventory_${rowId}_`) === 0) {
                    attr.remove();
                }
            });
        }

        function addInventory(charId, item, qty) {
            let existingRow = findRow(charId, item.name);
            if (existingRow) {
                const currentCount = getInventoryCount(charId, existingRow);
                setInventoryCount(charId, existingRow, currentCount + qty);
                return;
            }

            const newRow = rowID();
            setOrCreateAttr(charId, `repeating_inventory_${newRow}_itemname`, item.name);
            setOrCreateAttr(charId, `repeating_inventory_${newRow}_itemcount`, qty);
            setOrCreateAttr(charId, `repeating_inventory_${newRow}_itemweight`, item.weight || 0);
            setOrCreateAttr(charId, `repeating_inventory_${newRow}_itemcontent`, item.desc || "");
        }

        function removeInventory(charId, item, qty) {
            const existingRow = findRow(charId, item.name);
            if (!existingRow) return { ok: false, reason: "not_found" };

            const currentCount = getInventoryCount(charId, existingRow);
            if (currentCount < qty) return { ok: false, reason: "not_enough", count: currentCount };

            const newCount = currentCount - qty;
            if (newCount <= 0) {
                removeInventoryRow(charId, existingRow);
            } else {
                setInventoryCount(charId, existingRow, newCount);
            }

            return { ok: true, remaining: newCount };
        }

        function groupedItems() {
            const groups = {};
            Object.keys(ITEM_DATA).forEach(function (key) {
                const item = ITEM_DATA[key];
                const cat = item.category || "Custom";
                if (!groups[cat]) groups[cat] = [];
                groups[cat].push({ key: key, item: item });
            });
            return groups;
        }

        function buyerFromSelected(msgObj) {
            if (!msgObj.selected || !msgObj.selected.length) return null;
            const token = getObj("graphic", msgObj.selected[0]._id);
            if (!token) return null;
            const charId = token.get("represents");
            if (!charId) return null;
            return getObj("character", charId);
        }

        function merchantFromArg(tokenId) {
            if (!tokenId) return null;
            const token = getObj("graphic", tokenId);
            if (!token) return null;
            const merchantId = token.get("represents");
            if (!merchantId) return null;
            return getObj("character", merchantId);
        }

        function stockAttrFromKey(key) {
            return `${key}_stock`;
        }

        function clearShopStock(merchantId) {
            let cleared = 0;
            Object.keys(ITEM_DATA).forEach(function (key) {
                const stockAttr = ITEM_DATA[key].stockAttr;
                const attr = getAttr(merchantId, stockAttr);
                if (attr) {
                    attr.remove();
                    cleared++;
                }
            });
            return cleared;
        }

        // -------------------------
        // GM: ITEM MANAGEMENT
        // -------------------------

        // !additem key|Name|Cost|Weight|Category|Description
        if (msg.content.startsWith("!additem ")) {
            if (!isGM(msg)) return whisper(msg, "GM only.");

            const raw = msg.content.slice("!additem ".length);
            const parts = raw.split("|");
            if (parts.length < 6) {
                return whisper(msg, "Usage: !additem key|Name|Cost|Weight|Category|Description");
            }

            const key = sanitizeKey(parts[0]);
            const name = parts[1].trim();
            const cost = parseFloat(parts[2]);
            const weight = parseFloat(parts[3]);
            const category = parts[4].trim() || "Custom";
            const desc = parts.slice(5).join("|").trim();

            if (!key) return whisper(msg, "Invalid key.");
            if (!name) return whisper(msg, "Name required.");
            if (isNaN(cost) || cost < 0) return whisper(msg, "Invalid cost.");
            if (isNaN(weight) || weight < 0) return whisper(msg, "Invalid weight.");
            if (ITEM_DATA[key]) return whisper(msg, "That item key already exists.");

            ITEM_DATA[key] = {
                name: name,
                cost: cost,
                stockAttr: stockAttrFromKey(key),
                weight: weight,
                desc: desc,
                category: category
            };

            whisper(msg, `Added item: ${key}`);
            return;
        }

        // !removeitem item_key
        if (msg.content.startsWith("!removeitem ")) {
            if (!isGM(msg)) return whisper(msg, "GM only.");

            const key = sanitizeKey(msg.content.slice("!removeitem ".length));
            if (!ITEM_DATA[key]) return whisper(msg, "Item not found.");

            delete ITEM_DATA[key];
            whisper(msg, `Removed item: ${key}`);
            return;
        }

        // !items
        if (msg.content === "!items") {
            if (!isGM(msg)) return whisper(msg, "GM only.");

            const keys = Object.keys(ITEM_DATA);
            if (!keys.length) return whisper(msg, "No items exist yet.");

            let out = "<div style='border:1px solid #5a3b1e;background:#f3e3b0;padding:8px;color:#2b1a0b;'>";
            out += "<div style='font-weight:bold;font-size:1.2em;'>Custom Item Catalog</div>";

            const groups = groupedItems();
            Object.keys(groups).forEach(function (cat) {
                out += `<div style='margin-top:8px;font-weight:bold;'>${cat}</div>`;
                groups[cat].forEach(function (entry) {
                    out += `${entry.key} — ${entry.item.name} (${entry.item.cost} gp)<br>`;
                });
            });

            out += "</div>";
            whisper(msg, out);
            return;
        }

        // -------------------------
        // GM: TEMPLATE MANAGEMENT
        // -------------------------

        // !addtemplate template_key|item_key:qty,item_key:qty
        if (msg.content.startsWith("!addtemplate ")) {
            if (!isGM(msg)) return whisper(msg, "GM only.");

            const raw = msg.content.slice("!addtemplate ".length);
            const split = raw.split("|");
            if (split.length < 2) {
                return whisper(msg, "Usage: !addtemplate template_key|item_key:qty,item_key:qty");
            }

            const templateKey = sanitizeKey(split[0]);
            const itemsPart = split.slice(1).join("|").trim();
            const stock = {};

            itemsPart.split(",").forEach(function (pair) {
                const bits = pair.split(":");
                const itemKey = sanitizeKey(bits[0] || "");
                const qty = parseInt(bits[1] || "0", 10);
                if (itemKey && ITEM_DATA[itemKey] && Number.isInteger(qty) && qty >= 0) {
                    stock[itemKey] = qty;
                }
            });

            TEMPLATES[templateKey] = {
                name: templateKey,
                stock: stock
            };

            whisper(msg, `Added template: ${templateKey}`);
            return;
        }

        // !templates
        if (msg.content === "!templates") {
            if (!isGM(msg)) return whisper(msg, "GM only.");

            const keys = Object.keys(TEMPLATES);
            if (!keys.length) return whisper(msg, "No templates exist yet.");

            let out = "<div style='border:1px solid #5a3b1e;background:#f3e3b0;padding:8px;color:#2b1a0b;'>";
            out += "<div style='font-weight:bold;font-size:1.2em;'>Available Templates</div>";
            keys.forEach(function (k) {
                out += `${k}<br>`;
            });
            out += "</div>";
            whisper(msg, out);
            return;
        }

        // !loadtemplate template_key @{target|Merchant|token_id}
        if (msg.content.startsWith("!loadtemplate ")) {
            if (!isGM(msg)) return whisper(msg, "GM only.");

            const parts = msg.content.trim().split(/\s+/);
            const templateKey = sanitizeKey(parts[1] || "");
            const merchantTokenId = parts[2];
            const merchant = merchantFromArg(merchantTokenId);
            const template = TEMPLATES[templateKey];

            if (!merchant) return whisper(msg, "Target a merchant token.");
            if (!template) return whisper(msg, "Template not found.");

            const cleared = clearShopStock(merchant.id);

            let added = 0;
            Object.keys(template.stock).forEach(function (itemKey) {
                if (ITEM_DATA[itemKey]) {
                    setOrCreateAttr(merchant.id, ITEM_DATA[itemKey].stockAttr, template.stock[itemKey]);
                    added++;
                }
            });

            whisper(msg, `Template loaded. Cleared ${cleared}, added ${added}.`);
            return;
        }

        // !clearshop @{target|Merchant|token_id}
        if (msg.content.startsWith("!clearshop")) {
            if (!isGM(msg)) return whisper(msg, "GM only.");

            const parts = msg.content.trim().split(/\s+/);
            const merchantTokenId = parts[1];
            const merchant = merchantFromArg(merchantTokenId);

            if (!merchant) return whisper(msg, "Target a merchant token.");

            const cleared = clearShopStock(merchant.id);
            whisper(msg, `Shop cleared. Removed ${cleared} stock entries.`);
            return;
        }

        // -------------------------
        // GM: STOCK MANAGEMENT
        // -------------------------

        // !stock @{target|Merchant|token_id}
        if (msg.content.startsWith("!stock")) {
            if (!isGM(msg)) return whisper(msg, "GM only.");

            const parts = msg.content.trim().split(/\s+/);
            const merchantTokenId = parts[1];
            const merchant = merchantFromArg(merchantTokenId);

            if (!merchant) return whisper(msg, "Target a merchant token.");

            const groups = groupedItems();
            let out = "<div style='border:1px solid #5a3b1e;background:#f3e3b0;padding:8px;color:#2b1a0b;'>";
            out += `<div style='font-weight:bold;font-size:1.2em;'>${merchant.get("name")} — Stock Summary</div>`;

            Object.keys(groups).forEach(function (cat) {
                out += `<div style='margin-top:8px;font-weight:bold;'>${cat}</div>`;
                groups[cat].forEach(function (entry) {
                    const item = entry.item;
                    const attr = getAttr(merchant.id, item.stockAttr);
                    const stock = attr ? getAttrValue(merchant.id, item.stockAttr, 0) : 0;
                    out += `${item.name}: ${stock}<br>`;
                });
            });

            out += "</div>";
            whisper(msg, out);
            return;
        }

        // !setstock item_key qty @{target|Merchant|token_id}
        if (msg.content.startsWith("!setstock ")) {
            if (!isGM(msg)) return whisper(msg, "GM only.");

            const parts = msg.content.trim().split(/\s+/);
            const key = sanitizeKey(parts[1] || "");
            const qty = parseInt(parts[2] || "0", 10);
            const merchantTokenId = parts[3];
            const merchant = merchantFromArg(merchantTokenId);

            if (!ITEM_DATA[key]) return whisper(msg, "Invalid item key.");
            if (!Number.isInteger(qty) || qty < 0) return whisper(msg, "Quantity must be 0 or more.");
            if (!merchant) return whisper(msg, "Target a merchant token.");

            setOrCreateAttr(merchant.id, ITEM_DATA[key].stockAttr, qty);
            whisper(msg, `Set ${ITEM_DATA[key].name} stock to ${qty} for ${merchant.get("name")}.`);
            return;
        }

        // !restock item_key qty @{target|Merchant|token_id}
        if (msg.content.startsWith("!restock ")) {
            if (!isGM(msg)) return whisper(msg, "GM only.");

            const parts = msg.content.trim().split(/\s+/);
            const key = sanitizeKey(parts[1] || "");
            const qty = parseInt(parts[2] || "0", 10);
            const merchantTokenId = parts[3];
            const merchant = merchantFromArg(merchantTokenId);

            if (!ITEM_DATA[key]) return whisper(msg, "Invalid item key.");
            if (!Number.isInteger(qty) || qty < 1) return whisper(msg, "Quantity must be 1 or more.");
            if (!merchant) return whisper(msg, "Target a merchant token.");

            const oldStock = getAttrValue(merchant.id, ITEM_DATA[key].stockAttr, 0);
            const newStock = oldStock + qty;
            setOrCreateAttr(merchant.id, ITEM_DATA[key].stockAttr, newStock);

            whisper(msg, `Restocked ${ITEM_DATA[key].name}: ${oldStock} → ${newStock}`);
            return;
        }

        // -------------------------
        // PLAYER: SHOP
        // -------------------------

        // !shop @{target|Merchant|token_id}
        if (msg.content.startsWith("!shop")) {
            const parts = msg.content.trim().split(/\s+/);
            const merchantTokenId = parts[1];
            const merchant = merchantFromArg(merchantTokenId);

            if (!merchant) return whisper(msg, "Target a merchant token.");

            const groups = groupedItems();
            let foundAny = false;
            let out = "<div style='border:1px solid #5a3b1e;background:#f3e3b0;padding:8px;color:#2b1a0b;'>";
            out += `<div style='font-weight:bold;font-size:1.2em;'>${merchant.get("name")}</div>`;
            out += "<div style='margin-bottom:8px;'>Select your token, then click to buy.</div>";

            Object.keys(groups).forEach(function (cat) {
                let catOut = "";

                groups[cat].forEach(function (entry) {
                    const key = entry.key;
                    const item = entry.item;
                    const attr = getAttr(merchant.id, item.stockAttr);
                    if (!attr) return;

                    const stock = getAttrValue(merchant.id, item.stockAttr, 0);
                    if (stock <= 0) return;

                    foundAny = true;
                    catOut += "<div style='margin-bottom:6px;padding-bottom:6px;border-bottom:1px dotted #8b6b3f;'>";
                    catOut += `<b>${item.name}</b> — ${item.cost} gp (Stock: ${stock})<br>`;
                    catOut += `<span style='font-size:0.9em;'>${item.desc}</span><br>`;
                    catOut += `${button(`!buy ${key} 1 ${merchantTokenId}`, "Buy 1")} ${button(`!buy ${key} 2 ${merchantTokenId}`, "Buy 2")}`;
                    catOut += "</div>";
                });

                if (catOut) {
                    out += `<div style='margin-top:8px;font-weight:bold;border-top:1px solid #8b6b3f;padding-top:4px;'>${cat}</div>`;
                    out += catOut;
                }
            });

            if (!foundAny) out += "<div>This shop currently has nothing available.</div>";
            out += "</div>";

            whisper(msg, out);
            return;
        }

        // !buy item_key qty @{target|Merchant|token_id}
        if (msg.content.startsWith("!buy ")) {
            const parts = msg.content.trim().split(/\s+/);
            const key = sanitizeKey(parts[1] || "");
            const qty = parseInt(parts[2] || "1", 10);
            const merchantTokenId = parts[3];

            if (!ITEM_DATA[key]) return whisper(msg, "Invalid item key.");
            if (!Number.isInteger(qty) || qty < 1) return whisper(msg, "Quantity must be 1 or more.");

            const buyer = buyerFromSelected(msg);
            const merchant = merchantFromArg(merchantTokenId);

            if (!buyer) return whisper(msg, "Select your token before buying.");
            if (!merchant) return whisper(msg, "Target a merchant token.");

            const item = ITEM_DATA[key];
            const gold = getAttrValue(buyer.id, GOLD_ATTR, 0);
            const stock = getAttrValue(merchant.id, item.stockAttr, 0);
            const cost = item.cost * qty;

            if (stock < qty) return whisper(msg, `${item.name} is out of stock. Available: ${stock}.`);
            if (gold < cost) return whisper(msg, `Not enough gold. Need ${cost} gp, have ${gold} gp.`);

            const newGold = Math.round((gold - cost) * 100) / 100;
            const newStock = stock - qty;

            setOrCreateAttr(buyer.id, GOLD_ATTR, newGold);
            setOrCreateAttr(merchant.id, item.stockAttr, newStock);
            addInventory(buyer.id, item, qty);
            appendNote(buyer.id, `Bought ${qty}x ${item.name} from ${merchant.get("name")}`);

            whisper(msg, `Bought ${qty}x ${item.name} from ${merchant.get("name")}. Gold left: ${newGold}.`);
            return;
        }

        // !sell item_key qty @{target|Merchant|token_id}
        if (msg.content.startsWith("!sell ")) {
            const parts = msg.content.trim().split(/\s+/);
            const key = sanitizeKey(parts[1] || "");
            const qty = parseInt(parts[2] || "1", 10);
            const merchantTokenId = parts[3];

            if (!ITEM_DATA[key]) return whisper(msg, "Invalid item key.");
            if (!Number.isInteger(qty) || qty < 1) return whisper(msg, "Quantity must be 1 or more.");

            const buyer = buyerFromSelected(msg);
            const merchant = merchantFromArg(merchantTokenId);

            if (!buyer) return whisper(msg, "Select your token before selling.");
            if (!merchant) return whisper(msg, "Target a merchant token.");

            const item = ITEM_DATA[key];
            const result = removeInventory(buyer.id, item, qty);

            if (!result.ok) {
                if (result.reason === "not_found") return whisper(msg, `You do not have ${item.name}.`);
                if (result.reason === "not_enough") return whisper(msg, `You only have ${result.count}x ${item.name}.`);
            }

            const gold = getAttrValue(buyer.id, GOLD_ATTR, 0);
            const merchantStock = getAttrValue(merchant.id, item.stockAttr, 0);
            const saleValue = Math.round((item.cost * SELL_RATE * qty) * 100) / 100;
            const newGold = Math.round((gold + saleValue) * 100) / 100;
            const newMerchantStock = merchantStock + qty;

            setOrCreateAttr(buyer.id, GOLD_ATTR, newGold);
            setOrCreateAttr(merchant.id, item.stockAttr, newMerchantStock);
            appendNote(buyer.id, `Sold ${qty}x ${item.name} to ${merchant.get("name")}`);

            whisper(msg, `Sold ${qty}x ${item.name} to ${merchant.get("name")}. Gold now: ${newGold}.`);
            return;
        }

        // !sellshop @{target|Merchant|token_id}
        if (msg.content.startsWith("!sellshop")) {
            const parts = msg.content.trim().split(/\s+/);
            const merchantTokenId = parts[1];
            const merchant = merchantFromArg(merchantTokenId);
            const buyer = buyerFromSelected(msg);

            if (!merchant) return whisper(msg, "Target a merchant token.");
            if (!buyer) return whisper(msg, "Select your token first.");

            const groups = groupedItems();
            let foundAny = false;
            let out = "<div style='border:1px solid #5a3b1e;background:#f3e3b0;padding:8px;color:#2b1a0b;'>";
            out += `<div style='font-weight:bold;font-size:1.2em;'>${merchant.get("name")} — Sell Items</div>`;

            Object.keys(groups).forEach(function (cat) {
                let catOut = "";

                groups[cat].forEach(function (entry) {
                    const key = entry.key;
                    const item = entry.item;
                    const rowId = findRow(buyer.id, item.name);
                    if (!rowId) return;

                    const count = getInventoryCount(buyer.id, rowId);
                    if (count <= 0) return;

                    foundAny = true;
                    const sellPrice = Math.round((item.cost * SELL_RATE) * 100) / 100;
                    catOut += "<div style='margin-bottom:6px;padding-bottom:6px;border-bottom:1px dotted #8b6b3f;'>";
                    catOut += `<b>${item.name}</b> — Sell for ${sellPrice} gp each (You have: ${count})<br>`;
                    catOut += `${button(`!sell ${key} 1 ${merchantTokenId}`, "Sell 1")}`;
                    if (count >= 2) catOut += ` ${button(`!sell ${key} 2 ${merchantTokenId}`, "Sell 2")}`;
                    catOut += "</div>";
                });

                if (catOut) {
                    out += `<div style='margin-top:8px;font-weight:bold;border-top:1px solid #8b6b3f;padding-top:4px;'>${cat}</div>`;
                    out += catOut;
                }
            });

            if (!foundAny) out += "<div>You have nothing this merchant will currently buy.</div>";
            out += "</div>";

            whisper(msg, out);
            return;
        }

    } catch (err) {
        sendChat("Merchant", `/w gm ERROR: ${err.message}`);
        log(err.stack);
    }
});
